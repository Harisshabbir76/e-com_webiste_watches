{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://e-com-webiste-watches.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}

